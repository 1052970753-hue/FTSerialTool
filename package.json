{
  "name": "ftserialtool",
  "version": "1.2.4",
  "description": "FT serial protocol workbench",
  "repository": "https://github.com/1052970753-hue/FTSerialTool",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check src/app.js && node --check src/protocol-parser.js && node --check src/main.js && node --check src/preload.js",
    "test": "node ./scripts/test-protocol-parser.js",
    "clean": "powershell -ExecutionPolicy Bypass -File ./scripts/clean.ps1",
    "compact:win": "powershell -ExecutionPolicy Bypass -File ./scripts/compact-win.ps1",
    "pack:win": "powershell -ExecutionPolicy Bypass -File ./scripts/package-win.ps1",
    "pack:portable": "powershell -ExecutionPolicy Bypass -File ./scripts/package-portable-win.ps1",
    "serve:updates": "node ./scripts/update-server.js",
    "publish:github": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-github.ps1",
    "release:github": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-github.ps1 -Release"
  },
  "devDependencies": {
    "electron": "^31.7.7"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
